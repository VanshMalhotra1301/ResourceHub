{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/",
      "status": 302,
      "headers": {
        "Location": "/login"
      }
    },
    {
      "src": "/login",
      "dest": "/pages/auth/auth.html"
    },
    {
      "src": "/signup",
      "dest": "/pages/auth/signup.html"
    },
    {
      "src": "/home",
      "dest": "/index.html"
    },
    {
      "src": "/test",
      "dest": "/pages/auth/test_auth.html"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
