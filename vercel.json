{
  "redirects": [
    {
      "source": "/",
      "destination": "/login",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/login",
      "destination": "/pages/auth/auth.html"
    },
    {
      "source": "/signup",
      "destination": "/pages/auth/signup.html"
    },
    {
      "source": "/home",
      "destination": "/index.html"
    },
    {
      "source": "/test",
      "destination": "/pages/auth/test_auth.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
